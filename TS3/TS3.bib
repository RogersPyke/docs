
@misc{liu_sundial_2025,
	title = {Sundial: {A} {Family} of {Highly} {Capable} {Time} {Series} {Foundation} {Models}},
	shorttitle = {Sundial},
	url = {http://arxiv.org/abs/2502.00816},
	doi = {10.48550/arXiv.2502.00816},
	abstract = {We introduce Sundial, a family of native, flexible, and scalable time series foundation models. To predict the next-patch's distribution, we propose a TimeFlow Loss based on flow-matching, which facilitates native pre-training of Transformers on continuous-valued time series without discrete tokenization. Conditioned on arbitrary-length time series, our models are pre-trained without specifying any prior distribution and can generate multiple probable predictions, achieving more flexibility in representation learning than using parametric densities. Towards time series foundation models, we leverage minimal but crucial adaptations of Transformers and curate TimeBench with one trillion time points, comprising mostly real-world datasets and synthetic data. By mitigating mode collapse via TimeFlow Loss, we pre-train a family of Sundial models on TimeBench, which achieve unprecedented model capacity and generalization performance. In addition to excellent scalability, Sundial achieves state-of-the-art results on both point and probabilistic forecasting benchmarks with a just-in-time inference speed, i.e., making zero-shot predictions within a few milliseconds. We believe that Sundial's pioneering generative forecasting capability can improve model reliability in real-world decision-making. Code is available at: https://github.com/thuml/Sundial.},
	urldate = {2026-03-23},
	publisher = {arXiv},
	author = {Liu, Yong and Qin, Guo and Shi, Zhiyuan and Chen, Zhi and Yang, Caiyin and Huang, Xiangdong and Wang, Jianmin and Long, Mingsheng},
	month = nov,
	year = {2025},
	note = {arXiv:2502.00816 [cs]},
	keywords = {Computer Science - Machine Learning},
	annote = {\_原始数据流匹配时序基础模型：


划分 Patch把原始时间序列按照固定的 Patch Size（比如 30 帧）切成若干块。每块内部保持原始的连续数值，不做离散化。


Patch‑Embed对每个 Patch，先把它的帧拼接成一个一维向量（长度 = Patch Size × 每帧特征维度），再通过一个 MLP（线性投影）映射到模型内部的 嵌入维度 \$D\$。这一步得到的向量就相当于 Token。




Transformer 编码把所有 Token 按顺序送进 decoder‑only Transformer。Transformer 通过自注意力把每个 Token 与其它 Token 进行信息交互，最终为每个 Patch 生成一个上下文表示 \$hᵢ\$。其中 \$hₙ\$（即最后一个已知 Patch 的表示）已经融合了前面 N‑1 个 Patch 的全部信息。


TimeFlow（流匹配）生成以 \$hₙ\$ 作为条件，结合一个从标准高斯分布采样的随机噪声，使用 FM‑Net（流匹配网络）进行 \$K\$ 步的迭代推理。每一步都会把噪声稍微“推向”目标分布，完成后得到的向量就是 下一个 Patch 的预测。因为噪声是随机的，你可以多次采样得到多条可能的未来序列，从而估计不确定性。


所以，整体上可以把它看成：

原始序列 → Patch 切分 → MLP 嵌入 → Transformer 自注意力 → 最后一个 Token 的嵌入 \$hₙ\$ → FM‑Net 生成下一个 Patch。


研究故事
冲突（Problem）
传统的时间序列模型往往先把连续数值离散成字符或标签，再用语言模型的交叉熵进行训练。离散化导致信息丢失、模式崩塌，且只能给出单一的点预测，难以表达不确定性。
转折（Motivation）
生成式大模型（如 VLA）已经证明，在原始连续空间直接建模 能产生更丰富的输出。Sundial 把这一思路搬到时间序列上，提出 TimeFlow Loss，让 Transformer 在每个 patch 上学习完整的概率分布，而不是单一的 token。
方案（Method）


Patch 划分：把序列按固定长度（如 30 帧）切成若干块，每块保持原始数值。


Patch‑Embed（MLP）：把每个 patch 拼成 30 · N 维向量，线性投影到统一的嵌入维度 D（512/768/1024）。


Transformer 编码：使用 RoPE、Pre‑LN、FlashAttention、KV Cache 等增强，使所有 token 并行交互，得到每个 patch 的上下文表示 hᵢ。


TimeFlow（Flow‑Matching）：以最后一个 token 的表示 hₙ 为条件，结合随机噪声通过 FM‑Net 进行 K 步迭代，直接生成下一个 patch 的概率分布。多次采样即可得到多样化的预测和不确定性区间。


形象比喻
把时间序列看成一段连续的音乐。传统方法像是把每个音符先转成离散的符号，再让模型记忆这些符号；Sundial 则把原始的波形切成小段（patch），每段直接喂给模型，让它在完整的声波上学习“音色”。随后，模型像即兴演奏一样，从已有的乐句（hₙ）出发，随机生成多种可能的后续段落。
隐藏的代价（The Catch）


大规模预训练：需要 万亿级 时间点和多张 A100 GPU，普通实验室难以直接复现。


对帧维度的统一要求：所有输入必须在同一批次里保持相同的特征维度，需要额外的线性投影或填充。


高频数据仍有挑战：论文主要在中低频序列上评估，极高采样率的细节可能未被充分捕获。


快速要点（Quick Takeaways）


原生连续建模：不做离散化，直接在原始数值上学习。


Patch‑Transformer‑Flow：三段式流水线实现高效并行与生成式预测。


显著提升：在多项零样本基准（TSLib、GIFT‑Eval、FEV）上实现 SOTA，且提供多样化不确定性估计。


},
	file = {Preprint PDF:/Users/rogers/Zotero/storage/6EGI7YYT/Liu 等 - 2025 - Sundial A Family of Highly Capable Time Series Foundation Models.pdf:application/pdf;Snapshot:/Users/rogers/Zotero/storage/WHYIDQVZ/2502.html:text/html},
}

@misc{qiu_adapt_2026,
	title = {Adapt {Data} to {Model}: {Adaptive} {Transformation} {Optimization} for {Domain}-shared {Time} {Series} {Foundation} {Models}},
	shorttitle = {Adapt {Data} to {Model}},
	url = {https://arxiv.org/abs/2603.00629v1},
	abstract = {Large time series models (LTMs) have emerged as powerful tools for universal forecasting, yet they often struggle with the inherent diversity and nonstationarity of real-world time series data, leading to an unsatisfactory trade-off between forecasting accuracy and generalization. Rather than continually finetuning new LTM instances for each domain, we propose a data-centric framework, time-series adaptive transformation optimization (TATO), that enables a single frozen pre-trained LTM to adapt to diverse downstream domains through an optimally configured transformation pipeline. Specifically, TATO constructs three representative types of transformations, including context slicing, scale normalization, and outlier correction, to help LTMs better align with target domain characteristics. To ensure robustness, we incorporate carefully selected time series augmentations and a two-stage ranking mechanism that filters out pipelines underperforming on specific metrics. Extensive experiments on state-of-the-art LTMs and widely used datasets demonstrate that TATO consistently and significantly improves domain-adaptive forecasting performance, achieving a maximum reduction in MSE of 65.4{\textbackslash}\% and an average reduction of 13.6{\textbackslash}\%. Moreover, TATO is highly efficient, typically completing optimization in under 2 minutes, making it practical for real-world deployment. The source code is available at https://github.com/thulab/TATO.},
	language = {en},
	urldate = {2026-05-07},
	journal = {arXiv.org},
	author = {Qiu, Yunzhong and Cen, Zhiyao and Pei, Zhongyi and Wang, Chen and Wang, Jianmin},
	month = feb,
	year = {2026},
	annote = {\_时序-冻结模型数据-仅预处理优化：
文章核心是使用一系列固定顺序的数据预处理方法的超参数组合优化替代针对每一个领域的数据的专门Embedding/Learned-Adapter。将原本的超多参数优化简化为了几个超参数的优化问题，效果很好的同时计算量和所需的数据大幅度减少。
具体的方法是得到一个方案（参数组）-{\textgreater}在多个指标上评价-{\textgreater}选取Pareto Front-{\textgreater}在Pareto Front里选取认为最好的（基于偏好）。
这里选取候选方案的方法是TPE贝叶斯优化。算法基于已有信息进行概率密度估计，然后迭代。一般需要500个Trial才能得到合适的方案\$h{\textasciicircum}*\$.

这里简单介绍Pareto：
帕累托最优（Pareto Optimality）也就是不被任何人支配的解集合。支配：简单来说，就像是向量里每一个元素\$e\_A\$都大于等于\$e\_B\$而且同时至少存在一个\$e\_\{A,i\} {\textgreater} e\_\{B,j\}\$.这里每一个元素就是一个评价指标。
若一个方案\$h{\textasciicircum}*\$不被任何其他任意方案\$h\_i\$支配，则他是一个Pareto最优解，属于Pareto Front。也就是：将这些最优解在几何空间中连接起来，就形成了帕累托前沿（Pareto Front）。
Pareto Front 代表了当前问题下性能的极限边界。站在帕累托前沿上，意味着系统潜力已被榨干，任何想要进一步提升某一个指标的行为，都必然要以牺牲其他指标为代价。这正是多目标优化中经典的权衡（Trade-off）关系——没有绝对的“最好”，只有在不同指标间做出的“最佳妥协”。
结合我们的笔记背景，TPE 贝叶斯优化算法经过约 500 次 Trial 的迭代，最终收敛并筛选出的正是这样一组帕累托最优的超参数组合。这一步相当于客观地绘制出了一张“最优权衡地图”，剔除了所有低效的参数方案。随后，我们就可以根据实际业务对各个指标的具体偏好（例如更看重推理速度还是更看重精度），在这张帕累托前沿地图上精准地选取那个最适合当前场景的最终方案\$h\_\{opti\}\$ 。
},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/TM6IWRK9/Qiu 等 - 2026 - Adapt Data to Model Adaptive Transformation Optimization for Domain-shared Time Series Foundation M.pdf:application/pdf},
}

@misc{qiao_its_2026,
	title = {It's {TIME}: {Towards} the {Next} {Generation} of {Time} {Series} {Forecasting} {Benchmarks}},
	shorttitle = {It's {TIME}},
	url = {https://arxiv.org/abs/2602.12147v3},
	abstract = {Time series foundation models (TSFMs) are revolutionizing the forecasting landscape from specific dataset modeling to generalizable task evaluation. However, we contend that existing benchmarks exhibit common limitations in four dimensions: constrained data composition dominated by reused legacy sources, compromised data integrity lacking rigorous quality assurance, misaligned task formulations detached from real-world contexts, and rigid analysis perspectives that obscure generalizable insights. To bridge these gaps, we introduce TIME, a next-generation task-centric benchmark comprising 50 fresh datasets and 98 forecasting tasks, tailored for strict zero-shot TSFM evaluation free from data leakage. Integrating large language models and human expertise, we establish a rigorous human-in-the-loop benchmark construction pipeline to ensure high data integrity and redefine task formulation by aligning forecasting configurations with real-world operational requirements and variate predictability. Furthermore, we propose a novel pattern-level evaluation perspective that moves beyond traditional dataset-level evaluations based on static meta labels. By leveraging structural time series features to characterize intrinsic temporal properties, this approach offers generalizable insights into model capabilities across diverse patterns. We evaluate 12 representative TSFMs and establish a multi-granular leaderboard to facilitate in-depth analysis and visualized inspection. The leaderboard is available at https://huggingface.co/spaces/Real-TSF/TIME-leaderboard.},
	language = {en},
	urldate = {2026-05-07},
	journal = {arXiv.org},
	author = {Qiao, Zhongzheng and Pan, Sheng and Wang, Anni and Zhukova, Viktoriya and Liu, Yong and Jiang, Xudong and Wen, Qingsong and Long, Mingsheng and Jin, Ming and Liu, Chenghao},
	month = feb,
	year = {2026},
	annote = {\_时序-基于时序特征的TSFM新Bench：
1 Intro
现在的时间序列预测基准（TSF Bench）主要存在四个问题：


数据来源受限且易泄漏：很多基准仍旧使用旧有的、已经被大模型预训练数据所覆盖的老数据集，导致模型在评测时可能出现“数据泄漏”，进而夸大了性能提升。


数据质量不足：数据的质量检查往往不够严格，常会出现极端异常值、缺失值过多或噪声过大的变量，影响评测的可靠性。


任务设置与实际需求脱节：基准往往采用固定的预测窗口和频率，缺乏对真实业务场景的考虑，导致模型在实验中表现好，却不一定适用于实际应用。


分析视角过于粗糙：评测只按数据集的领域或采样频率进行划分并给出整体平均分，忽略了不同序列之间在趋势、季节性等结构特征上的相似性，难以解释模型为何在某些情况下表现更好，也不利于用户根据具体需求选模型。


其中最大的问题是4: 按照业务而不是内在结构性联系进行划分。

观点：结构性是数据非常重要的特征。机器人数据，金融或者其他领域数据具有各自显著的数据特征，如何利用这些数据特征进行学习可以说是模型架构设计的最大重点，因此这才是所谓不同“领域”的根本。

2.2 Time Series Features
tsfeature是时序特征，也是作者主张的时序分类的核心根本。
补充一个关键问题：传统的基准往往只在数据集层面 进行特征划分——把整个数据集看作一个整体，统计它的整体趋势、季节性强度、复杂度等，然后用这些宏观指标来评估模型。这样做虽然能给出一个大致的概览，却会掩盖同一业务场景内部的细微差异。
在实际的时间序列中，即使它们来源于同一个领域（比如电力负荷、零售销量或气象监测），每条序列的内部结构也可能大相径庭。作者通过 STL 分解 把每条序列拆解成趋势、季节性和残差，并提取出七个结构化特征。随后，用二进制阈值（大于中位数记 1、否则记 0）为每条序列生成一个 模式向量，相同向量的序列被归入同一 cluster。
6.3 Pattern‑specific Performance（模式层级表现）
本小节的核心在于 把时间序列按结构化特征（tsfeatures）划分为若干二元模式，并在每一种模式下分别统计 12 种 Time‑Series Foundation Models（TSFMs）的预测误差（MASE、CRPS），从而观察模型在不同时间‑特性上的相对优势与劣势。
1.选取的特征（六个结构化特征）




编号


特征


含义




F₁


Trend Strength


趋势占整体波动的比例




F₂


Trend Linearity


趋势的线性程度




F₃


Seasonality Strength


季节性成分的强度




F₄


Seasonality Correlation


不同季节周期之间的相似度




F₅


Residual ACF‑1


残差的一阶自相关（残差是否仍有结构）




F₆


