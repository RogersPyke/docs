@misc{bai_efficient_2024,
	title = {Efficient {Pretraining} {Data} {Selection} for {Language} {Models} via {Multi}-{Actor} {Collaboration}},
	url = {https://arxiv.org/abs/2410.08102v3},
	abstract = {Efficient data selection is crucial to accelerate the pretraining of language model (LMs). While various methods have been proposed to enhance data efficiency, limited research has addressed the inherent conflicts between these approaches to achieve optimal data selection for LM pretraining. To tackle this problem, we propose a multi-actor collaborative data selection mechanism: each data selection method independently prioritizes data based on its criterion and updates its prioritization rules using the current state of the model, functioning as an independent actor for data selection; and a console is designed to adjust the impacts of different actors at various stages and dynamically integrate information from all actors throughout the LM pretraining process. We conduct extensive empirical studies to evaluate our multi-actor framework. The experimental results demonstrate that our approach significantly improves data efficiency, accelerates convergence in LM pretraining, and achieves an average relative performance gain up to \$10.5{\textbackslash}\%\$ across multiple language model benchmarks compared to the state-of-the-art methods.},
	language = {en},
	urldate = {2026-05-25},
	journal = {arXiv.org},
	author = {Bai, Tianyi and Yang, Ling and Wong, Zhen Hao and Sun, Fupeng and Peng, Jiahui and Zhuang, Xinlin and Zhang, Chi and Wu, Lijun and Qiu, Jiantao and Zhang, Wentao and Yuan, Binhang and He, Conghui},
	month = oct,
	year = {2024},
	annote = {\_语言-多Actor-影响函数-强化学习-数据筛选：
1. 研究目标
提升大规模语言模型预训练的效率，使模型在更少的 token 上快速收敛并在下游任务上取得更好表现。
2. 多角色（Multi‑Actor）框架




角色


负责的度量


实现方式




质量 Actor


评估数据的质量


使用轻量的质量评分模型（如 FineWeb‑Edu）对每条数据打分




主题 Actor


评估数据的主题多样性


通过 BERT‑style 主题分类器把数据划分为若干主题并给出分数




领域 Actor


评估数据的来源领域


直接依据数据的元信息（Wikipedia、C4、GitHub 等）给出分数




每个 Actor 都维护一个 权重向量（对应不同子类别的权重），并在每轮训练后根据 奖励 更新这些权重。
3. 奖励函数——影响函数


单样本梯度：对一条预训练样本计算交叉熵损失的梯度。


参考任务梯度：在若干下游参考任务（如 LAMBADA、SQuAD、Jeopardy）上计算整体损失的梯度。


Hessian：对参考任务损失的二阶导数矩阵，描述梯度随参数变化的曲率。


影响函数将单样本梯度通过 Hessian 的逆映射到对参考任务损失的影响上，得到每条样本的 奖励。正奖励表示该样本有助于提升参考任务表现，负奖励则相反。
4. 参数更新机制


Actor 内部权重（\$w\_j{\textasciicircum}A\$）


使用滑动平均：\$[w\_j{\textasciicircum}A {\textbackslash}leftarrow (1-{\textbackslash}eta\_A) w\_j{\textasciicircum}A + {\textbackslash}eta\_A {\textbackslash}bar R\_j{\textasciicircum}A]\$


(\${\textbackslash}bar R\_j{\textasciicircum}A\$) 为该 Actor 在当前子类别上的平均奖励。


这一步相当于强化学习中的策略梯度，把奖励直接映射到采样概率上。




协同权重（\$({\textbackslash}theta\_A)\$）


计算每个 Actor 的整体奖励 (\$R\_A\$) 与全局平均奖励 (\${\textbackslash}bar R\$)。


按梯度上升方式更新：\$[ {\textbackslash}theta\_A {\textbackslash}leftarrow {\textbackslash}theta\_A + {\textbackslash}eta\_A (R\_A - {\textbackslash}bar R) ]\$


当某 Actor 的奖励高于平均值时，它的 (\${\textbackslash}theta\$) 增大，在总分中占更大比重；反之则减小。




总分计算\$[ S(x\_i) = {\textbackslash}theta\_\{{\textbackslash}text\{Quality\}\} S\_\{{\textbackslash}text\{Quality\}\}(x\_i) + {\textbackslash}theta\_\{{\textbackslash}text\{Domain\}\} S\_\{{\textbackslash}text\{Domain\}\}(x\_i) + {\textbackslash}theta\_\{{\textbackslash}text\{Topic\}\} S\_\{{\textbackslash}text\{Topic\}\}(x\_i) ]\$


这里的 \$(S\_\{{\textbackslash}text\{*\}\}(x\_i))\$ 为该数据在对应 Actor 中的分数（即对应子类别的权重）。


按总分排序，选取 Top‑K 条数据喂给主模型进行一次训练。




5. 训练循环


采样：每个 Actor 按当前权重采样子集。


奖励计算：利用影响函数得到每条样本的奖励。


权重更新：分别更新 Actor 内部权重和协同权重。


数据选取：依据总分挑选最有价值的 Top‑K 数据。


模型训练：对选中的数据进行一次前向‑反向传播，更新主模型参数。


循环：回到第 1 步，直至预设的 token 预算或训练步数结束。


6. 实验结果


在 1.3 B、3.6 B、8 B 参数的 LLaMA‑2 变体上，平均提升约 10 \% 的下游任务准确率。


与最强基线（如 QuRating、MATES）相比，计算 FLOPs 约为其一半至七分之一。


多角色协同显著加速收敛，尤其在早期训练阶段表现更为突出。


7. 结论


多角色协同 能够在质量、主题、领域三维度之间动态平衡，解决单一度量的冲突问题。


影响函数 为每条样本提供了可解释的贡献度量，直接用于奖励信号，驱动 Actor 的在线学习。


该框架在不同模型规模和多任务评测上均表现出更高的 数据效率 与 计算效率，为大规模语言模型的预训练提供了一条更经济、更快速的路径。


},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/IEP7IDX6/Bai 等 - 2024 - Efficient Pretraining Data Selection for Language Models via Multi-Actor Collaboration.pdf:application/pdf},
}

@misc{xie_data_2023,
	title = {Data {Selection} for {Language} {Models} via {Importance} {Resampling}},
	url = {http://arxiv.org/abs/2302.03169},
	doi = {10.48550/arXiv.2302.03169},
	abstract = {Selecting a suitable pretraining dataset is crucial for both general-domain (e.g., GPT-3) and domain-specific (e.g., Codex) language models (LMs). We formalize this problem as selecting a subset of a large raw unlabeled dataset to match a desired target distribution given unlabeled target samples. Due to the scale and dimensionality of the raw text data, existing methods use simple heuristics or require human experts to manually curate data. Instead, we extend the classic importance resampling approach used in low-dimensions for LM data selection. We propose Data Selection with Importance Resampling (DSIR), an efficient and scalable framework that estimates importance weights in a reduced feature space for tractability and selects data with importance resampling according to these weights. We instantiate the DSIR framework with hashed n-gram features for efficiency, enabling the selection of 100M documents from the full Pile dataset in 4.5 hours. To measure whether hashed n-gram features preserve the aspects of the data that are relevant to the target, we define KL reduction, a data metric that measures the proximity between the selected pretraining data and the target on some feature space. Across 8 data selection methods (including expert selection), KL reduction on hashed n-gram features highly correlates with average downstream accuracy (r=0.82). When selecting data for continued pretraining on a specific domain, DSIR performs comparably to expert curation across 8 target distributions. When pretraining general-domain models (target is Wikipedia and books), DSIR improves over random selection and heuristic filtering baselines by 2-2.5\% on the GLUE benchmark. Code is available at https://github.com/p-lambda/dsir.},
	urldate = {2026-05-28},
	publisher = {arXiv},
	author = {Xie, Sang Michael and Santurkar, Shibani and Ma, Tengyu and Liang, Percy},
	month = nov,
	year = {2023},
	note = {arXiv:2302.03169 [cs.CL]},
	keywords = {Computer Science - Computation and Language, Computer Science - Machine Learning},
	annote = {\_语言-基于高低质量对比-词袋分解-语言模型-重要性采样:
已知高质量子集，词袋稀缺程度重合度采样从全量数据采样同样词袋高质量子集。
\#\# 核心背景：为什么要选择数据？
训练大语言模型就像教学生读书。如果你给学生看太多杂乱无章、充满废话的网页信息（比如原始的互联网数据），他学到的知识也会很零碎。为了让模型在特定领域（比如医疗、编程）或者通用领域表现更好，研究人员通常需要从一个巨大的“原始仓库”中挑选出最像“教科书”（目标数据）的内容。
过去的方法要么靠专家手动挑选（太慢），要么靠简单的规则（比如通过关键词过滤，不够灵活）。DSIR 则提供了一种既快又科学的自动化方案。

\#\# DSIR 方法拆解：它是如何工作的？
即便你没有背景知识，也可以将 DSIR 的过程想象成一个**“智能筛选漏斗”**。它主要分为三个步骤：
\#\#\# 1. 提取“特征”（把文字变成数字）
直接处理成千上亿行的文字非常慢且复杂。DSIR 采用了一种叫 “哈希 n-gram” (Hashed n-gram) 的技术。


n-gram：就是把一句话切成由 \$n\$ 个词组成的片段（比如“我爱学习”可以切成“我爱”、“爱学”、“学习”）。


哈希 (Hashed)：为了节省空间，它把这些词片段通过数学变换变成一个个数字编号。


作用：这就好比不再去读整本书，而是统计每本书里某些关键词频次的“配方表”。Feature Space


\#\#\# 2. 计算“重要性权重”（衡量有多像目标）
假设你手里有一小份高质量的“样板数据”（比如维基百科），还有一堆巨大的“原始数据”（比如整个互联网）。


DSIR 会对比两者的“配方表”。


如果某个特征在“样板数据”中经常出现，但在“原始数据”中很少见，那么包含这个特征的数据就被认为具有高权重，也就是更“重要”。Importance Weights


\#\#\# 3. 智能抽样（重采样）
有了权重后，我们不是简单地只选分最高的那些数据（因为那会导致数据太单一，比如全是同一篇好文章的副本），而是进行重采样。


这就像一场有偏向的抽样：权重越高的数据，被选中的概率越大。


这样选出来的最终数据集，在统计分布上会非常接近你的“样板数据”，同时又保持了足够的多样性。Resampling



\#\# 为什么这个方法很厉害？


速度极快：它可以在 4.5 小时内处理完包含 1 亿个文档的超大数据集（The Pile）。Efficiency


效果显著：在通用语言模型的测试（GLUE）中，用 DSIR 选出的数据训练出来的模型，比随机选数据训练出的模型准确率提升了 2\% 到 2.5\%。Results


科学的衡量指标：作者提出了 KL Reduction 指标。简单来说，这个指标能通过数学计算，在不训练模型的情况下，提前预测出这批选出的数据到底好不好用。实验证明，这个指标与模型最终的考试分数（准确率）高度相关。



“由于 KL 还原与下游任务性能高度相关，且计算成本极低（无需训练模型），它可以作为未来数据选择方法的‘健康检查’。” KL Reduction

},
	annote = {Comment: NeurIPS 2023},
	file = {Preprint PDF:/Users/rogers/Zotero/storage/UI3IPLZ6/Xie 等 - 2023 - Data Selection for Language Models via Importance Resampling.pdf:application/pdf;Snapshot:/Users/rogers/Zotero/storage/UHA8PIPW/2302.html:text/html},
}

@misc{paul_deep_2021,
	title = {Deep {Learning} on a {Data} {Diet}: {Finding} {Important} {Examples} {Early} in {Training}},
	shorttitle = {Deep {Learning} on a {Data} {Diet}},
	url = {https://arxiv.org/abs/2107.07075v2},
	abstract = {Recent success in deep learning has partially been driven by training increasingly overparametrized networks on ever larger datasets. It is therefore natural to ask: how much of the data is superfluous, which examples are important for generalization, and how do we find them? In this work, we make the striking observation that, in standard vision datasets, simple scores averaged over several weight initializations can be used to identify important examples very early in training. We propose two such scores -- the Gradient Normed (GraNd) and the Error L2-Norm (EL2N) scores -- and demonstrate their efficacy on a range of architectures and datasets by pruning significant fractions of training data without sacrificing test accuracy. In fact, using EL2N scores calculated a few epochs into training, we can prune half of the CIFAR10 training set while slightly improving test accuracy. Furthermore, for a given dataset, EL2N scores from one architecture or hyperparameter configuration generalize to other configurations. Compared to recent work that prunes data by discarding examples that are rarely forgotten over the course of training, our scores use only local information early in training. We also use our scores to detect noisy examples and study training dynamics through the lens of important examples -- we investigate how the data distribution shapes the loss surface and identify subspaces of the model's data representation that are relatively stable over training.},
	language = {en},
	urldate = {2026-05-28},
	journal = {arXiv.org},
	author = {Paul, Mansheej and Ganguli, Surya and Dziugaite, Gintare Karolina},
	month = jul,
	year = {2021},
	annote = {\_GraNd\&EL2N样本难度度量-样本难度在训练在早期就可见:
论文的核心贡献就是提出了两种在训练早期即可计算的快速难度评分——梯度范数（GraNd）和误差 L2‑范数（EL2N），并通过大量实验证明，这两种评分能够有效地挑选出对模型学习最关键的样本，从而实现高效的数据剪枝和课程学习。
},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/RZIKR9R6/Paul 等 - 2021 - Deep Learning on a Data Diet Finding Important Examples Early in Training.pdf:application/pdf},
}

@misc{pennino_optimizing_2025,
	title = {Optimizing the {Training} {Diet}: {Data} {Mixture} {Search} for {Robust} {Time} {Series} {Forecasting}},
	shorttitle = {Optimizing the {Training} {Diet}},
	url = {https://arxiv.org/abs/2512.11546v1},
	abstract = {The standard paradigm for training deep learning models on sensor data assumes that more data is always better. However, raw sensor streams are often imbalanced and contain significant redundancy, meaning that not all data points contribute equally to model generalization. In this paper, we show that, in some cases, "less is more" when considering datasets. We do this by reframing the data selection problem: rather than tuning model hyperparameters, we fix the model and optimize the composition of the training data itself. We introduce a framework for discovering the optimal "training diet" from a large, unlabeled time series corpus. Our framework first uses a large-scale encoder and k-means clustering to partition the dataset into distinct, behaviorally consistent clusters. These clusters represent the fundamental 'ingredients' available for training. We then employ the Optuna optimization framework to search the high-dimensional space of possible data mixtures. For each trial, Optuna proposes a specific sampling ratio for each cluster, and a new training set is constructed based on this recipe. A smaller target model is then trained and evaluated. Our experiments reveal that this data-centric search consistently discovers data mixtures that yield models with significantly higher performance compared to baselines trained on the entire dataset. Specifically - evaluated on PMSM dataset - our method improved performance from a baseline MSE of 1.70 to 1.37, a 19.41\% improvement.},
	language = {en},
	urldate = {2026-06-01},
	journal = {arXiv.org},
	author = {Pennino, Federico and Gabbrielli, Maurizio},
	month = dec,
	year = {2025},
	annote = {\_时序-数据分箱采样比优化问题-基于训练评估-选择数据：
1. 针对什么问题？
在利用传感器监控机器（如电机）时，人们通常认为**“数据越多越好”。但实际上，海量数据中充满了大量重复、没用且乱七八糟的信息**，这就像吃饭时吞下了太多没有营养的“填料”，不仅让模型学得慢，还会干扰它掌握核心规律。
2. 基于什么假设？
文章基于一个核心假设：“少即是多”。 研究者认为，并不是所有数据都对学习有帮助。如果能把数据像食材一样分类，然后只挑选出那些最有营养、最能反映机器运行特征的“核心食材”进行搭配，模型即便吃得更少（数据量更小），也能长得更壮（预测更准）。 Abstract
3. 方法是什么？
这套方法被称为打造“训练餐单”，分为三步：


第一步：自动归类。利用电脑程序把乱如麻的数据自动分堆，一共分成36个“盒子”，每个盒子代表机器的一种运行状态（比如启动、停止、加速等）。


第二步：配比搜索。雇佣一个“自动化教练”（优化器）来做实验。教练会不断尝试：从盒子A拿10\%的数据，盒子B拿80\%的数据……拼凑出一份份不同的“试吃餐单”。


第三步：实战演练。用每一份餐单训练出一个预测模型，谁的表现好，教练就记住这套配比。最终找到那套黄金配比。 Pipeline


4. 实验如何证明有效？
研究者拿一个电动机温度预测的真实场景进行了测试：


数据量减半：经过筛选后的最优数据量只有原来的 43\%。


准确度大幅提升：虽然数据少了一大半，但预测的准确度反而提升了约 20\%。


证明了“去粗取精”的威力：实验发现，被教练丢弃的数据大多是机器关机时的静默信号或无意义的杂音，而保留的都是反映机器性能的关键瞬间。 Results


},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/YYCRM362/Pennino和Gabbrielli - 2025 - Optimizing the Training Diet Data Mixture Search for Robust Time Series Forecasting.pdf:application/pdf},
}

@misc{sachdeva_how_2024,
	title = {How to {Train} {Data}-{Efficient} {LLMs}},
	url = {http://arxiv.org/abs/2402.09668},
	doi = {10.48550/arXiv.2402.09668},
	abstract = {The training of large language models (LLMs) is expensive. In this paper, we study data-efficient approaches for pre-training LLMs, i.e., techniques that aim to optimize the Pareto frontier of model quality and training resource/data consumption. We seek to understand the tradeoffs associated with data selection routines based on (i) expensive-to-compute data-quality estimates, and (ii) maximization of coverage and diversity-based measures in the feature space. Our first technique, Ask-LLM, leverages the zero-shot reasoning capabilities of instruction-tuned LLMs to directly assess the quality of a training example. To target coverage, we propose Density sampling, which models the data distribution to select a diverse sample. In our comparison of 19 samplers, involving hundreds of evaluation tasks and pre-training runs, we find that Ask-LLM and Density are the best methods in their respective categories. Coverage sampling can recover the performance of the full data, while models trained on Ask-LLM data consistently outperform full-data training -- even when we reject 90\% of the original dataset, while converging up to 70\% faster.},
	urldate = {2026-06-06},
	publisher = {arXiv},
	author = {Sachdeva, Noveen and Coleman, Benjamin and Kang, Wang-Cheng and Ni, Jianmo and Hong, Lichan and Chi, Ed H. and Caverlee, James and McAuley, Julian and Cheng, Derek Zhiyuan},
	month = feb,
	year = {2024},
	note = {arXiv:2402.09668 [cs.LG]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Machine Learning, Computer Science - Computation and Language},
	annote = {\_语言-特征空间密度采样-LSH投影降维-分布优先的采样：
来自谷歌DeepMind的一篇研究。
1. 研究背景与核心动机
大语言模型（LLM）的预训练受限于“缩放定律”（Scaling Laws），即单纯增加模型参数或数据量带来的收益呈指数级递减。为了优化预训练的帕累托前沿（在更少的计算资源下达到更好的模型性能），本文提出了两种互补的数据筛选策略：


ASK-LLM (质量维度)：利用指令微调模型作为“面试官”，直接评估数据的知识含量。


DENSITY (覆盖维度)：在特征空间建模数据分布，通过消除冗余提升数据的多样性与覆盖率。



2. DENSITY 方法：基于分布的覆盖率采样
DENSITY 的核心目标是：在语义特征空间中实现均匀采样。 它通过降低高密度区域（冗余数据）的权重，提升低密度区域（独特数据）的权重，使模型在有限的 Token 预算内见识到最广的话题。
2.1 技术流程流水线
该方法通过以下步骤实现流式处理：


特征提取：利用预训练的编码器（如 Sentence-T5）将文本映射到高维连续特征空间 \${\textbackslash}mathbb\{R\}{\textasciicircum}D\$（例如 768 维）。


随机线性投影（LSH）： 使用局部敏感哈希（LSH）将高维向量投影到多个随机方向，并进行离散化分箱。公式定义为： \$h(x) = {\textbackslash}lfloor {\textbackslash}frac\{a {\textbackslash}cdot x + b\}\{{\textbackslash}lambda\} {\textbackslash}rfloor\$ （基于随机向量\$x\$的线性投影，并加上向下取整） 。其中 \$a\$ 是从 \$p\$-稳定分布采样的随机投影向量，\$b\$ 是随机偏移，\${\textbackslash}lambda\$ 是控制分辨率的带宽。


构建统计速写（Sketch Matrix）： 维护一个 \$R {\textbackslash}times B\$ 的计数矩阵（\$R\$ 为哈希函数个数，\$B\$ 为桶数。哈希函数的个数取决于随机值\$x\$、\$b\$、\$λ\$。）。


第一遍扫描（Pass 1）：计算每条数据的哈希位置，并在矩阵对应格子执行 +1。该矩阵最终成为特征空间的“人口分布地图”。




密度评估与反向采样：


第二遍扫描（Pass 2）：重新计算数据的哈希位置，从矩阵中提取 \$R\$ 个视角的计数值并求平均，得到该点的密度得分 \$S(x)\$。




概率抽签： 计算采样概率 \$p(x) {\textbackslash}propto {\textbackslash}frac\{1\}\{S(x)\}\$。通过伯努利抽签决定该数据是否进入最终训练集。（1）这里的伯努利抽签指的是，无关于其他样本条目，单独只针对它进行非一即零的抽签。有采样概率 \$p(x)\$ 的概率得到一，也就是被抽签。有 \$1 - p(x)\$ 概率抽到0，也就是不被抽签。（2）如果说想要对整个被采样的比例进行缩放，只需要在这一步乘以一个factor。比如，只想要采样整个数据集中百分之十的数据集做训练，那么这里的factor就是 0.1。



3. 为什么选择“投影 + 哈希”？（核心权衡分析）
在处理数亿级数据时，DENSITY 避开了传统几何方法的死穴：
3.1 破解“维度诅咒” (Curse of Dimensionality)
在高维空间（如 768 维），点与点之间的距离趋于一致，传统的近邻搜索会失效。


降维视角：LSH 并不是为了精确区分，而是通过随机线性投影找到多个“低维切面”。


距离保持：根据数学特性，在原始空间相近的点，投影后在数轴上依然靠得近，从而保证了碰撞（进入同一个桶）的概率与原始密度正相关。


3.2 计算量与复杂度的降级


对抗 \$O(N{\textasciicircum}2)\$：如果直接做密度估计，需要计算全量数据的成对相似度，这在工程上是不可行的。哈希将复杂度降为 \$O(N {\textbackslash}cdot R)\$，即线性时间复杂度。


极致的内存压缩：由于不存储原始特征向量和索引，只存储计数的“速写矩阵”，本研究仅用 80MB 内存便完成了对 3.6 亿条数据的密度建模。


3.3 存储与索引的权衡


无须存标签：两阶段扫描（Two-Pass）的设计避免了存储海量数据的采样标签。通过“实时重算哈希”代替“读取 TB 级索引”，极大优化了 I/O 效率。


3.4 缺陷
由于需要现场计算LSH进行概率轨估计，还是得存样本自己的特征向量-{\textgreater}LSH才能计算（因为是feature-based LSH）。要么就只能保存编码器模型，现场计算映射到特征空间，然后再映射到LSH。所以要么因为feature的维度比较大，七百六十八维，存储大概需要花个一T的空间，同时还要处理原始样本索引到feature的映射，要么就只能使用编码器模型现场计算。计算时间长。

4. ASK-LLM 方法简述
作为 DENSITY 的补充，ASK-LLM 侧重于数据质量而非分布。


逻辑：给定一段文本，询问代理 LLM（如 Flan-T5）：“这段文字是否有助于预训练？是否有价值？”


优势：它能识别出传统“困惑度（Perplexity）”无法过滤的语义冗余或逻辑垃圾（例如没有答案的问题、无休止的自我重复）。


结论：ASK-LLM 在极低采样率（如仅保留 10\% 数据）时表现惊人，能够显著超越全量数据训练的效果。



5. 对跨领域研究的启示


分布优先：在任何需要提升覆盖面的领域，DENSITY 提供的“反频率采样”都是一种通用且廉价的工具。


带宽 \${\textbackslash}lambda\$ 的调节：在其他领域应用时，\${\textbackslash}lambda\$ 的设置应参考特征空间内数据的平均距离，它决定了识别冗余的粒度。


多视角平滑：使用多个哈希函数（\$R\$ 较大）是保证密度估计稳健的关键，能有效抵御分箱边界带来的随机误差。


},
	annote = {Comment: Under review. 44 pages, 30 figures},
	file = {Preprint PDF:/Users/rogers/Zotero/storage/7T8WDNTB/Sachdeva 等 - 2024 - How to Train Data-Efficient LLMs.pdf:application/pdf;Snapshot:/Users/rogers/Zotero/storage/WNYR7763/2402.html:text/html},
}

@misc{liu_quadmix_2025,
	title = {{QuaDMix}: {Quality}-{Diversity} {Balanced} {Data} {Selection} for {Efficient} {LLM} {Pretraining}},
	copyright = {Creative Commons Attribution 4.0 International},
	shorttitle = {{QuaDMix}},
	url = {https://arxiv.org/abs/2504.16511},
	doi = {10.48550/ARXIV.2504.16511},
	abstract = {Quality and diversity are two critical metrics for the training data of large language models (LLMs), positively impacting performance. Existing studies often optimize these metrics separately, typically by first applying quality filtering and then adjusting data proportions. However, these approaches overlook the inherent trade-off between quality and diversity, necessitating their joint consideration. Given a fixed training quota, it is essential to evaluate both the quality of each data point and its complementary effect on the overall dataset. In this paper, we introduce a unified data selection framework called QuaDMix, which automatically optimizes the data distribution for LLM pretraining while balancing both quality and diversity. Specifically, we first propose multiple criteria to measure data quality and employ domain classification to distinguish data points, thereby measuring overall diversity. QuaDMix then employs a unified parameterized data sampling function that determines the sampling probability of each data point based on these quality and diversity related labels. To accelerate the search for the optimal parameters involved in the QuaDMix framework, we conduct simulated experiments on smaller models and use LightGBM for parameters searching, inspired by the RegMix method. Our experiments across diverse models and datasets demonstrate that QuaDMix achieves an average performance improvement of 7.2\% across multiple benchmarks. These results outperform the independent strategies for quality and diversity, highlighting the necessity and ability to balance data quality and diversity.},
	urldate = {2026-06-06},
	publisher = {arXiv},
	author = {Liu, Fengze and Zhou, Weidong and Liu, Binbin and Yu, Zhimiao and Zhang, Yifan and Lin, Haobin and Yu, Yifeng and Zhang, Bingni and Zhou, Xiaohuan and Wang, Taifeng and Cao, Yong},
	year = {2025},
	note = {Version Number: 2},
	keywords = {Computation and Language (cs.CL), FOS: Computer and information sciences},
	annote = {\_语言-质量和多样性权衡-打分排名-训练反馈循环超参数优化：
字节
1. 核心挑战：质量与多样性的权衡
在 LLM 预训练中，数据**质量（Quality）和多样性（Diversity）**通常是相互冲突的。传统的做法是先进行硬性的质量过滤，再手动调整领域比例。这种做法忽略了两者之间的耦合关系：特定的质量过滤器往往会无意中偏向某些领域，从而破坏整体的多样性。
2. QuaDMix 框架设计
QuaDMix 提出了一种统一的参数化方案，将数据选择从“人工筛选”转向“数学优化”。
数据标注


领域标签：利用分类器为每个文档标记所属领域 \$m\$。


质量标签：利用多个预训练好的打分器（如 DCLM、Fineweb-edu 等）提取多维度质量分。


排名与合并
在每个领域内部，系统利用权重参数 \${\textbackslash}alpha\$ 将不同维度的质量分合并，并计算该文档在所属领域内的百分比排名 \${\textbackslash}bar\{r\}\$。这种设计允许不同领域拥有不同的“好数据”标准。
3. 核心数学模型：软阈值采样函数
QuaDMix 不使用传统的硬过滤，而是通过一个参数化的 Sigmoid 函数来决定每个文档的采样频率 \$S({\textbackslash}bar\{r\})\$。
\$S({\textbackslash}bar\{r\}) = {\textbackslash}left( {\textbackslash}frac\{2\}\{1+e{\textasciicircum}\{-{\textbackslash}lambda\_m({\textbackslash}omega\_m-{\textbackslash}bar\{r\})\}\} {\textbackslash}right){\textasciicircum}\{{\textbackslash}eta\_m\} + {\textbackslash}epsilon\_m\$
参数物理含义解读：


\${\textbackslash}omega\_m\$ (质量阈值)：决定了该领域的保留基准。若排名低于此值，采样频率会大幅下降。


\${\textbackslash}lambda\_m\$ (下降坡度)：控制过滤的严苛程度。值越大，越趋向于只保留极高质量的数据。


\${\textbackslash}eta\_m\$ (缩放系数)：调节高质量数据的“复读”次数，实现对精华数据的过采样。


\${\textbackslash}epsilon\_m\$ (多样性保底)：即使质量较差的数据也保留微小的采样概率，确保模型见识过长尾分布的知识，维持多样性。


4. 代理模型驱动的自动化搜索
为了避免在大规模模型上进行昂贵的尝试，QuaDMix 采用了代理模型优化的策略：


小规模实验：在 1M 参数的极小模型上进行 3000 次不同参数配置的训练实验。


回归建模：利用 LightGBM 训练一个回归模型，学习“参数配置 \${\textbackslash}to\$ 验证集性能”的对应规律。


最优预测：在回归模型上搜索预测 Loss 最小的参数组合，将其迁移至正式的 530M 模型训练中。


5. 核心洞察与结论


数据中心化（Data-centric）自动化：通过将数据选择抽象为一组可优化的超参数，实现了从“猜测数据比例”到“预测最优配方”的范式转变。


跨准则互补：合并多个质量打分器能有效减少单一工具的偏见，通过回归优化可以自动发现不同打分器在不同领域中的价值。


性能提升：这种联合优化的方法比单纯优化质量或单纯优化领域比例的方法性能更好，在主流基准测试中平均提升了约 7.2\%。


},
}

@misc{liang_enabling_2024,
	title = {Enabling {Time}-series {Foundation} {Model} for {Building} {Energy} {Forecasting} via {Contrastive} {Curriculum} {Learning}},
	url = {https://arxiv.org/abs/2412.17285v1},
	abstract = {Advances in time-series forecasting are driving a shift from conventional machine learning models to foundation models (FMs) that are trained with generalized knowledge. However, existing FMs still perform poorly in the energy fields, such as building energy forecasting (BEF). This paper studies the adaptation of FM to BEF tasks. We demonstrate the shortcomings of fine-tuning FM straightforwardly from both the perspectives of FM and the data. To overcome these limitations, we propose a new {\textbackslash}textit\{contrastive curriculum learning\}-based training method. Our method optimizes the ordering of training data in the context of TSFM adaptation. Experiments show that our method can improve the zero/few-shot performance by 14.6{\textbackslash}\% compared to the existing FMs. Our code and new TSFM will be available at {\textless}Anonymous Github Repo{\textgreater}.},
	language = {en},
	urldate = {2026-06-06},
	journal = {arXiv.org},
	author = {Liang, Rui and Deng, Yang and Xie, Donghua and He, Fang and Wang, Dan},
	month = dec,
	year = {2024},
	annote = {\_时序课程学习-对比学习找虚拟样本对应真是样本-进行难度传递:

1. 核心背景：通用模型的“水土不服”
虽然时间序列基础模型（TSFM）在天气、金融领域表现出色，但在**建筑能耗预测（BEF）**领域遇到了瓶颈：


数据稀缺与隐私：真实建筑能耗数据受隐私保护，极难获取；研究多依赖模拟软件生成的“假数据”。


微调效果差：直接用混合数据（真+假）对基础模型进行传统微调，准确率提升不到 1\%，无法满足工程需求。


模式复杂：不同建筑的用电模式受行为、气候、设备影响巨大，模型难以捕捉统一规律。


2. 核心方案：对比感知课程学习（CCL）
作者提出了一种“循序渐进”的适配方法，将训练过程分为难度评估和进度调度两个阶段。
A. 难度测量：给数据打分
该方法区分处理真实数据和模拟数据，解决“假数据难度难定义”的问题：


真实数据：直接看模型预测得准不准，误差越大，难度越高。


模拟数据（对比学习桥梁）：


逻辑：不看外形是否相似，看“模型理解起来是否一样难”。认为预测误差相近则理解程度相同，预测误差相差很大则理解程度相差很大。预测误差小则理解程度高，反之理解程度低。


做法：模拟样本的难度衡量不精确，因此需要找对应的真实样本作难度传递。构建正样本为预测相差小的样本对，负样本为预测相差大的样本对。训练出来的模型能够找到正样本对，也就是相差小的样本对，从而进行虚拟样本和真实样本的匹配-难度传递。


结果：将模拟样本映射到向量空间，找到与之对应的、难度已知的真实样本，从而实现难度的跨数据集传递。




B. 进度调度：从易到难


线性增长策略：训练初期只给模型看最简单的 20\% 样本。


动态调整：随着轮数增加，逐渐加入更高难度的样本，直到最后使用全量数据。


目的：让模型先掌握基础能耗规律（如季节性、昼夜规律），再学习复杂的异常波动。


3. 技术关键点


打破“视觉相似”陷阱：该方法强调“模型理解难度相似”而非物理波形的“形状相似”。


特征提取器：采用时间卷积网络（TCN）来提取建筑用电特有的日、周周期特征。


通用性强：在 IBM Granite 和 Amazon Chronos 两种不同架构的基础模型上均验证有效。


4. 实验结论


性能飞跃：相比直接微调，CCL 方法将预测误差降低了 10\% - 15\%。


零样本能力：即便在完全没见过的建筑上进行“盲测”（Zero-shot），其表现也优于许多专门训练的传统模型。


规模效应：随着微调数据集的增大，该方法展现出比传统微调更强的性能增长潜力。



一句话总结：该研究通过对比学习搭建了真假数据之间的“难度桥梁”，利用课程学习让 AI 从简单规律学起，成功将通用的时间序列模型转化为了专业的建筑能耗专家。
},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/58NG8V2A/Liang 等 - 2024 - Enabling Time-series Foundation Model for Building Energy Forecasting via Contrastive Curriculum Lea.pdf:application/pdf},
}

@misc{abel_dual-criterion_2026,
	title = {Dual-{Criterion} {Curriculum} {Learning}: {Application} to {Temporal} {Data}},
	shorttitle = {Dual-{Criterion} {Curriculum} {Learning}},
	url = {https://arxiv.org/abs/2603.23573v1},
	abstract = {Curriculum Learning (CL) is a meta-learning paradigm that trains a model by feeding the data instances incrementally according to a schedule, which is based on difficulty progression. Defining meaningful difficulty assessment measures is crucial and most usually the main bottleneck for effective learning, while also in many cases the employed heuristics are only application-specific. In this work, we propose the Dual-Criterion Curriculum Learning (DCCL) framework that combines two views of assessing instance-wise difficulty: a loss-based criterion is complemented by a density-based criterion learned in the data representation space. Essentially, DCCL calibrates training-based evidence (loss) under the consideration that data sparseness amplifies the learning difficulty. As a testbed, we choose the time-series forecasting task. We evaluate our framework on multivariate time-series benchmarks under standard One-Pass and Baby-Steps training schedules. Empirical results show the interest of density-based and hybrid dual-criterion curricula over loss-only baselines and standard non-CL training in this setting.},
	language = {en},
	urldate = {2026-06-06},
	journal = {arXiv.org},
	author = {Abel, Gaspard and Campagne, Eloi and Benloughmari, Mohamed and Kalogeratos, Argyris},
	month = mar,
	year = {2026},
	annote = {\_时序-增加密度/常见程度考虑的-课程学习新难度衡量：
1. 核心思想：给数据“排课表”
这篇文章的核心贡献在于：重新定义了什么是“简单”，什么是“难”。
2. 两个关键难度指标 (Dual-Criterion)
作者认为，仅靠模型表现来判断难度是不够的，需要结合“模型视角”和“数据视角”：


指标 A：预测损失 (Loss) —— “模型视角”


逻辑：模型预测得越准，样本就越简单。


特点：它是动态的，反映了模型当前的掌握程度。




指标 B：数据密度 (Density) —— “数据视角”


逻辑：数据模式越常见（密度高），就越简单。


特点：它是本质的，反映了数据是否属于“大众模式”。在时间序列中，典型的周期性规律就是高密度，而罕见的突发状况就是低密度。




3. 理解1 + 1 {\textgreater} 1
正如你在讨论中总结的，文章的核心逻辑是：在难度估计上做文章，把密度作为一个必选指标。


更好的难度估计：两个指标结合能提供比单一指标更全面、更稳健的评估。


互补效应：Loss 指标告诉模型“哪些还没学会”，Density 指标告诉模型“哪些是应该先稳固的基础规律”。


4. 技术实现路径
为了让这两个指标落地，作者设计了一套标准流程：


特征嵌入 (Embedding)：利用 Transformer 或 LSTM 将复杂的时间序列转化为向量空间中的点。


计算密度：在向量空间中通过 k-NN 或核密度估计（KDE）来衡量每个点的稀疏程度。


混合策略：


数值/排名加权：给 Loss 和 Density 各分配一个权重，算出一个综合难度分。


二维网格法 (Grid)：将 Loss 和 Density 作为两个坐标轴，将数据划分为不同的难度等级块。




5. 实验结论与启发


混合指标确实更强：在电力、流感、天气等多个数据集上，双准则的表现均优于单一指标。


对抗异常值：密度指标能有效识别出那些因稀少而导致的“假性困难”或“异常干扰”，防止模型在训练初期被极端样本带偏。


适用性广：这种“模型+数据”的双重评价体系不仅适用于时间序列，也可以推广到其他复杂的机器学习任务中。


},
	file = {Full Text PDF:/Users/rogers/Zotero/storage/BMMYVP3C/Abel 等 - 2026 - Dual-Criterion Curriculum Learning Application to Temporal Data.pdf:application/pdf},
}

@misc{ansari_chronos_2024,
	title = {Chronos: {Learning} the {Language} of {Time} {Series}},
	shorttitle = {Chronos},
	url = {http://arxiv.org/abs/2403.07815},
	doi = {10.48550/arXiv.2403.07815},
	abstract = {We introduce Chronos, a simple yet effective framework for pretrained probabilistic time series models. Chronos tokenizes time series values using scaling and quantization into a fixed vocabulary and trains existing transformer-based language model architectures on these tokenized time series via the cross-entropy loss. We pretrained Chronos models based on the T5 family (ranging from 20M to 710M parameters) on a large collection of publicly available datasets, complemented by a synthetic dataset that we generated via Gaussian processes to improve generalization. In a comprehensive benchmark consisting of 42 datasets, and comprising both classical local models and deep learning methods, we show that Chronos models: (a) significantly outperform other methods on datasets that were part of the training corpus; and (b) have comparable and occasionally superior zero-shot performance on new datasets, relative to methods that were trained specifically on them. Our results demonstrate that Chronos models can leverage time series data from diverse domains to improve zero-shot accuracy on unseen forecasting tasks, positioning pretrained models as a viable tool to greatly simplify forecasting pipelines.},
	urldate = {2026-06-07},
	publisher = {arXiv},
	author = {Ansari, Abdul Fatir and Stella, Lorenzo and Turkmen, Caner and Zhang, Xiyuan and Mercado, Pedro and Shen, Huibin and Shchur, Oleksandr and Rangapuram, Syama Sundar and Arango, Sebastian Pineda and Kapoor, Shubham and Zschiegner, Jasper and Maddix, Danielle C. and Wang, Hao and Mahoney, Michael W. and Torkkola, Kari and Wilson, Andrew Gordon and Bohlke-Schneider, Michael and Wang, Yuyang},
	month = nov,
	year = {2024},
	note = {arXiv:2403.07815 [cs.LG]},
	keywords = {Computer Science - Artificial Intelligence, Computer Science - Machine Learning},
	annote = {时序token化+语言模型架构预训练
数据多样性仅依赖领域覆盖+TSMixup/KernelSynth增强，无信号特征多样性，无课程学习。

**参考价值**：主流TSFM数据策略缺陷的典型证据。
},
	annote = {Comment: Code and model checkpoints available at https://github.com/amazon-science/chronos-forecasting},
